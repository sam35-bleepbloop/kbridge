# ─────────────────────────────────────────────────────────────────────────────
# K-Bridge — Environment Variables
# Copy this file to .env.local and fill in all values before running.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase) ──────────────────────────────────────────────────────
# Get both from: Supabase dashboard → Settings → Database → Connection string
# Use the "Transaction pooler" URL for DATABASE_URL (port 6543)
# Use the "Direct connection" URL for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-generated-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (for Google sign-in + Calendar access)
# Create at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── AI (Anthropic) ───────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=""
# Model to use — claude-sonnet is the right balance of capability and cost
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ── Stripe (token pack purchases) ───────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Token pack price IDs — create in Stripe dashboard as one-time prices
STRIPE_PRICE_STARTER="price_"   # 10 tokens — $15.00
STRIPE_PRICE_STANDARD="price_"  # 25 tokens — $37.50
STRIPE_PRICE_VALUE="price_"     # 50 tokens — $75.00

# ── Twilio (Korean SMS) ──────────────────────────────────────────────────────
# Get from: console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""  # Must be a number with international SMS capability

# ── Dwolla (US ACH payments) ─────────────────────────────────────────────────
# Apply at: developers.dwolla.com (allow 4-8 weeks for approval)
DWOLLA_KEY=""
DWOLLA_SECRET=""
DWOLLA_ENV="sandbox"  # Change to "production" when live
DWOLLA_WEBHOOK_SECRET=""

# ── Wise (cross-border FX) ───────────────────────────────────────────────────
# Apply at: wise.com/gb/business/api
WISE_API_TOKEN=""
WISE_PROFILE_ID=""
WISE_ENV="sandbox"  # Change to "live" when approved

# ── Adyen or Tazapay (card/wallet) ──────────────────────────────────────────
# Decision pending — add credentials here once gateway is selected
CARD_GATEWAY_KEY=""
CARD_GATEWAY_SECRET=""

# ── Google Calendar API ──────────────────────────────────────────────────────
# Uses same Google OAuth credentials above
GOOGLE_CALENDAR_SCOPES="https://www.googleapis.com/auth/calendar.events"

# ── App config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="K-Bridge"

# Fee configuration (stored here so they can be changed without code deploys)
BANK_ROUTE_FEE_PCT="0.015"      # 1.5%
CARD_ROUTE_FEE_PCT="0.040"      # 4.0%
MIN_FEE_USD="5.00"

# Token economy
WELCOME_BONUS_TOKENS="8"
LOW_TOKEN_ALERT_DAYS_BEFORE="5"  # Alert this many days before a scheduled payment
